# Environment
.env

# Article cache (large raw text files — not needed for the dashboard)
data/cache/*
!data/cache/.gitkeep

# Raw markdown cache (same treatment as data/cache/)
data/cache_raw_md/*
!data/cache_raw_md/.gitkeep

# Git worktrees
.worktrees/

# Local Claude Code settings
.claude/

# Pipeline log output
data/logs/

# Batch job artifacts
data/scores/*.jsonl

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Streamlit
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db
